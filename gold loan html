<script>
const { jsPDF } = window.jspdf;
let pieChart;
let lastResult = {};

function format(num){return '₹' + Math.round(num).toLocaleString('en-IN')}

function calculateGoldLoan(){
  const grams = parseFloat(document.getElementById('grams').value) || 20;
  const goldRate = parseFloat(document.getElementById('rate').value) || 7500;
  const P = parseFloat(document.getElementById('amount').value) || 100000;
  const r = (parseFloat(document.getElementById('interest').value)/100)/12 || 0.095/12;
  const n = parseInt(document.getElementById('months').value) || 12;
  
  let goldValue = grams * goldRate;
  let eligibleLoan = goldValue * 0.75; // 75% LTV
  let ltv = (P / goldValue) * 100;
  
  // EMI Formula = [P * r * (1+r)^n] / [(1+r)^n - 1]
  let emi = (P * r * Math.pow(1+r, n)) / (Math.pow(1+r, n) - 1);
  let totalPayment = emi * n;
  let totalInterest = totalPayment - P;
  
  lastResult = {grams, goldRate, goldValue, P, r, n, emi, totalPayment, totalInterest, eligibleLoan, ltv};
  
  document.getElementById('emi').innerText = format(emi);
  document.getElementById('interestAmt').innerText = format(totalInterest);
  document.getElementById('total').innerText = format(totalPayment);
  document.getElementById('goldValue').innerText = format(goldValue);
  document.getElementById('ltv').innerText = ltv.toFixed(1)+'%';
  document.getElementById('eligible').innerText = format(eligibleLoan);
  
  drawChart(P, totalInterest);
}

function drawChart(principal, interest){
  if(pieChart) pieChart.destroy();
  pieChart = new Chart(document.getElementById('pieChart'),{
    type:'pie',
    data:{
      labels:['Principal', 'Interest'],
      datasets:[{
        data:[principal, interest],
        backgroundColor:['#2563EB','#10B981'],
        borderWidth:0
      }]
    },
    options:{responsive:true, plugins:{legend:{position:'bottom'}}}
  });
}

function downloadPDF(){
    const doc = new jsPDF();
    doc.setFontSize(18); doc.text("Gold Loan Report", 14, 20);
    doc.setFontSize(10); doc.text("Rajaram Finance", 14, 27);
    let y=40;
    doc.setFontSize(12);
    doc.text(`Gold: ${lastResult.grams}g @ ${format(lastResult.goldRate)}/g`, 14, y); y+=10;
    doc.text(`Gold Value: ${format(lastResult.goldValue)}`, 14, y); y+=10;
    doc.text(`Loan Amount: ${format(lastResult.P)}`, 14, y); y+=10;
    doc.text(`Interest Rate: ${(lastResult.r*12*100).toFixed(1)}%`, 14, y); y+=10;
    doc.text(`Tenure: ${lastResult.n} Months`, 14, y); y+=10;
    doc.text(`Monthly EMI: ${format(lastResult.emi)}`, 14, y); y+=10;
    doc.text(`Total Interest: ${format(lastResult.totalInterest)}`, 14, y); y+=15;
    doc.setFontSize(9);
    doc.text("Disclaimer: Gold rates and LTV subject to bank policy.", 14, y);
    doc.save('Gold-Loan-Report.pdf');
}

document.getElementById("downloadPdf").addEventListener("click", downloadPDF);
window.onload = calculateGoldLoan;
</script>
