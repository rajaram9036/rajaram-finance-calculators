.card h2{font-size:20px;font-weight:700;color:#1E293B;margin-bottom:18px}

.input-group{margin-bottom:16px}
.input-group label{font-weight:600;margin-bottom:8px;font-size:14px;color:#475569;display:block}
.input-wrapper{position:relative}
.input-wrapper span{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:#64748B;font-weight:600;font-size:15px}
.input-wrapper input{width:100%;padding:14px 14px 14px 45px;border:1.5px solid var(--border);border-radius:8px;font-size:16px;font-weight:500;background:#fff}
.input-wrapper input:focus{border-color:var(--primary);outline:none}

.btn-primary{background:var(--primary);color:#fff;border:none;padding:15px;width:100%;border-radius:8px;font-size:16px;font-weight:700;cursor:pointer;letter-spacing:0.5px}
.btn-primary:hover{background:#1D4ED8}

.result-card{background:linear-gradient(135deg,#2563EB,#10B981);color:#fff;text-align:center;border:none}
.result-card .label{font-size:12px;opacity:0.9;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px}
.result-card .value{font-size:28px;font-weight:700;margin-bottom:16px}
.result-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:15px}
.result-mini{background:rgba(255,255,255,0.15);padding:12px;border-radius:8px}
.result-mini .label{font-size:11px}
.result-mini .value{font-size:15px;font-weight:700;margin-top:2px}

.btn-download{width:100%;background:var(--dark);color:#fff;border:none;padding:14px;border-radius:8px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;font-size:15px}
.btn-download:hover{background:#1E293B}

.content h2{font-size:22px;color:var(--primary);margin-bottom:12px}
.content p{line-height:1.8;color:#475569;margin-bottom:12px;font-size:15px}
.example-box{background:#EFF6FF;border-left:4px solid var(--primary);padding:16px;border-radius:8px;margin:15px 0}
.example-box b{color:var(--primary)}

.why-sip-grid{display:grid;gap:12px;margin:15px 0}
.why-item{display:flex;gap:12px;align-items:flex-start}
.why-item .num{background:var(--primary);color:#fff;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0}
.why-item p{margin:0;color:#475569}

.guide-box{background:#fff;border:2px dashed var(--primary);padding:24px;border-radius:12px;text-align:center;margin-top:20px}
.guide-box h2{font-size:20px;color:#1E293B;margin-bottom:10px}
.guide-box p{margin-bottom:15px;color:#475569}
.guide-btn{background:var(--primary);color:#fff;padding:14px 28px;border-radius:8px;text-decoration:none;font-weight:600;display:inline-block;font-size:15px}
.guide-btn:hover{background:#1D4ED8}

.tools-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
@media(min-width:600px){.tools-grid{grid-template-columns:repeat(3,1fr)}}
.tool-card{background:#F8FAFC;border:1.5px solid var(--border);padding:16px;border-radius:10px;text-decoration:none;color:var(--dark);text-align:center;font-weight:600;transition:0.2s}
.tool-card:hover{border-color:var(--primary);background:#EFF6FF;transform:translateY(-2px)}
.tool-card .icon{font-size:24px;margin-bottom:8px}

.disclaimer-box{background:#FEF3C7;border:1px solid #FBBF24;padding:16px;border-radius:8px;margin-top:15px;font-size:13px;line-height:1.6}
.disclaimer-box b{color:#92400E}

footer{background:var(--dark);color:#CBD5E1;padding:25px 20px;text-align:center;margin-top:30px}
.footer-links{display:flex;gap:18px;justify-content:center;flex-wrap:wrap;margin-bottom:12px}
.footer-links a{color:#94A3B8;text-decoration:none;font-size:14px}
.footer-links a:hover{color:#fff}
.copyright{font-size:13px;color:#64748B}
</style>
