<script>

function formatINR(value){
return "₹" + Math.round(value).toLocaleString("en-IN");
}

function calculateMF(){

let monthly = parseFloat(document.getElementById("sip").value);
let years = parseFloat(document.getElementById("years").value);
let annualRate = parseFloat(document.getElementById("rate").value);

if(isNaN(monthly) || isNaN(years) || isNaN(annualRate) ||
monthly<=0 || years<=0 || annualRate<=0){

alert("Please enter valid values.");

return;

}

let months = years * 12;

let monthlyRate = annualRate / 12 / 100;

let futureValue =
monthly *
((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate) *
(1 + monthlyRate);

let invested = monthly * months;

let returns = futureValue - invested;

document.getElementById("investedAmount").innerHTML =
formatINR(invested);

document.getElementById("estimatedReturns").innerHTML =
formatINR(returns);

document.getElementById("totalValue").innerHTML =
formatINR(futureValue);

document.getElementById("resultBox").style.display="block";

}

function resetMF(){

document.getElementById("sip").value="";
document.getElementById("years").value="";
document.getElementById("rate").value="";

document.getElementById("investedAmount").innerHTML="₹0";
document.getElementById("estimatedReturns").innerHTML="₹0";
document.getElementById("totalValue").innerHTML="₹0";

document.getElementById("resultBox").style.display="none";

}
</script>

